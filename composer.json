{
    "name": "bloggermohiuddin/storage",
    "description": "S3-compatible storage SDK for PHP — works on shared hosting, migrates to Cloudflare R2 or Amazon S3 with a config change",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.295"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "StorageSDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StorageSDK\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "migrate": "php migration/migrate.php"
    }
}
